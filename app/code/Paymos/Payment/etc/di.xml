<?xml version="1.0"?>
<!--
/**
 * Payment provider gateway wiring (the modern Magento payment integration).
 *
 * PaymosPaymentFacade is a virtual type of Magento\Payment\Model\Method\Adapter
 * configured with the three mandatory pools (value handler / validator /
 * command). This is the recommended approach; the legacy
 * Magento\Payment\Model\Method\AbstractMethod is @deprecated.
 *
 * @see https://developer.adobe.com/commerce/php/development/payments-integrations/base-integration/
 * @see https://developer.adobe.com/commerce/php/development/payments-integrations/payment-gateway/
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Payment method facade -->
    <virtualType name="PaymosPaymentFacade" type="Magento\Payment\Model\Method\Adapter">
        <arguments>
            <argument name="code" xsi:type="const">Paymos\Payment\Model\Ui\ConfigProvider::CODE</argument>
            <argument name="formBlockType" xsi:type="string">Magento\Payment\Block\Form</argument>
            <argument name="infoBlockType" xsi:type="string">Magento\Payment\Block\Info</argument>
            <argument name="valueHandlerPool" xsi:type="object">PaymosValueHandlerPool</argument>
            <argument name="validatorPool" xsi:type="object">PaymosValidatorPool</argument>
            <argument name="commandPool" xsi:type="object">PaymosCommandPool</argument>
        </arguments>
    </virtualType>

    <!-- Value handlers: read configuration from payment/paymos/* -->
    <virtualType name="PaymosValueHandlerPool" type="Magento\Payment\Gateway\Config\ValueHandlerPool">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="default" xsi:type="string">PaymosValueHandler</item>
            </argument>
        </arguments>
    </virtualType>

    <virtualType name="PaymosValueHandler" type="Magento\Payment\Gateway\Config\ConfigValueHandler">
        <arguments>
            <argument name="configInterface" xsi:type="object">PaymosGatewayConfig</argument>
        </arguments>
    </virtualType>

    <virtualType name="PaymosGatewayConfig" type="Magento\Payment\Gateway\Config\Config">
        <arguments>
            <argument name="methodCode" xsi:type="const">Paymos\Payment\Model\Ui\ConfigProvider::CODE</argument>
        </arguments>
    </virtualType>

    <!-- Validators: default pool (country/availability handled by the adapter) -->
    <virtualType name="PaymosValidatorPool" type="Magento\Payment\Gateway\Validator\ValidatorPool">
        <arguments>
            <argument name="validators" xsi:type="array"/>
        </arguments>
    </virtualType>

    <!-- Commands: a no-money authorize that defers the invoice to the redirect -->
    <virtualType name="PaymosCommandPool" type="Magento\Payment\Gateway\Command\CommandPool">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="authorize" xsi:type="string">Paymos\Payment\Gateway\Command\AuthorizeCommand</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Inject the configured method code into the gateway Config helper -->
    <type name="Paymos\Payment\Gateway\Config\Config">
        <arguments>
            <argument name="methodCode" xsi:type="const">Paymos\Payment\Model\Ui\ConfigProvider::CODE</argument>
            <argument name="pathPattern" xsi:type="const">Magento\Payment\Gateway\Config\Config::DEFAULT_PATH_PATTERN</argument>
        </arguments>
    </type>

    <!-- Module logger writes to var/log/paymos.log when debug is enabled -->
    <type name="Paymos\Payment\Service\Logger">
        <arguments>
            <argument name="name" xsi:type="string">Paymos</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">Paymos\Payment\Service\Logger\Handler</item>
            </argument>
        </arguments>
    </type>
</config>
