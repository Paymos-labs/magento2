<?xml version="1.0"?>
<!--
/**
 * Frontend route for the Paymos controllers:
 *   paymos/payment/redirect — create the invoice + redirect to hosted checkout
 *   paymos/payment/callback — receive signed Paymos webhooks
 *
 * @see https://developer.adobe.com/commerce/php/development/components/routing
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:App/etc/routes.xsd">
    <router id="standard">
        <route id="paymos" frontName="paymos">
            <module name="Paymos_Payment"/>
        </route>
    </router>
</config>
