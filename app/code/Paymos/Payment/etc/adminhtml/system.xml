<?xml version="1.0"?>
<!--
/**
 * Admin settings for the Paymos payment method.
 *
 * Exposes ONLY presentation + mode + order-status mapping. API credentials are
 * provisioned by Paymos Connect and encrypted in Magento. The "Connection status" row renders a diagnostics block with
 * masked keys / project id (Block\Adminhtml\System\Config\ConnectionStatus).
 *
 * @see https://experienceleague.adobe.com/en/docs/commerce-operations/configuration-guide/files/config-reference-systemxml
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="payment">
            <group id="paymos" translate="label" type="text" sortOrder="2" showInDefault="1" showInWebsite="1" showInStore="0">
                <label>Paymos (Pay with crypto)</label>
                <comment><![CDATA[Accept USDT / USDC and other crypto via Paymos hosted checkout. Use Connect Paymos below; official module archives contain no merchant secrets.]]></comment>

                <field id="active" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="title" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Title</label>
                    <comment>Name shown to customers on the checkout payment step.</comment>
                </field>

                <field id="mode" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Mode</label>
                    <source_model>Paymos\Payment\Model\Adminhtml\Source\Mode</source_model>
                    <comment>Sandbox uses test credentials; Live takes real payments. Connect Paymos for the selected mode before enabling checkout.</comment>
                </field>

                <field id="connection_status" translate="label" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Connection status</label>
                    <frontend_model>Paymos\Payment\Block\Adminhtml\System\Config\ConnectionStatus</frontend_model>
                </field>

                <field id="order_status" translate="label" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>New order status</label>
                    <source_model>Magento\Sales\Model\Config\Source\Order\Status\NewStatus</source_model>
                    <comment>Status applied while the customer is paying (before confirmation).</comment>
                </field>

                <field id="paid_order_status" translate="label" type="select" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Paid order status</label>
                    <source_model>Paymos\Payment\Model\Adminhtml\Source\ProcessingStatus</source_model>
                    <comment>Status applied once Paymos confirms the payment. The order is invoiced and moved to the Processing state.</comment>
                </field>

                <field id="debug" translate="label" type="select" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Debug logging</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Write diagnostics to var/log/paymos.log. Leave off in production.</comment>
                </field>

                <field id="sort_order" translate="label" type="text" sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Sort order</label>
                    <frontend_class>validate-number</frontend_class>
                </field>
            </group>
        </section>
    </system>
</config>
